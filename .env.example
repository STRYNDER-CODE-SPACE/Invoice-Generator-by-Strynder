NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Base URL for auth redirects (verification emails, password resets).
# Keep as localhost for local dev. In production (Vercel dashboard), set this to your deployed URL.
# If left as localhost, the code falls back to VERCEL_URL (auto-set by Vercel).
NEXT_PUBLIC_APP_URL=http://localhost:3000
